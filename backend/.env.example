# Railway / local backend environment variables

# Required: Umans Code API key from https://app.umans.ai/billing
# IMPORTANT: For deployed/production backends use a Wallet key (pay-by-token),
# not a personal Plan key. Plan keys are throttled/deprioritized for unattended
# automation and can be paused after repeated 429s.
UMANS_API_KEY=sk-your-umans-api-key

# Optional: web search backend. Options: native (Kimi-backed), exa, none
UMANS_WEBSEARCH_PROVIDER=native

# Optional: model alias. Options: umans-coder, umans-kimi-k2.7, umans-glm-5.2, umans-flash
UMANS_MODEL=umans-coder

# Optional: HTTP timeout in seconds for research calls
UMANS_RESEARCH_TIMEOUT=60

# Optional: dedicated model for social background research
UMANS_SOCIAL_MODEL=umans-coder

# Optional: dedicated model for document/deck extraction
UMANS_DOCUMENT_MODEL=umans-coder

# Optional: max tokens for LLM calls (default 8000)
UMANS_MAX_TOKENS=8000

# Legacy global web-search toggle. Per-agent toggles below take precedence.
# Optional: enable web-search tools in LLM calls (default true).
UMANS_ENABLE_WEB_SEARCH=true

# Per-agent web search toggles. These override UMANS_ENABLE_WEB_SEARCH.
# Sourcing needs real-time discovery, so it defaults to true.
UMANS_ENABLE_WEB_SEARCH_SOURCING=true
# Social research usually receives LinkedIn/GitHub URLs, so web search defaults
# to false to reduce API load. Set to true if you want the model to search.
UMANS_ENABLE_WEB_SEARCH_SOCIAL=false
# Founder research (POST /v1/founders/research) defaults to true.
UMANS_ENABLE_WEB_SEARCH_RESEARCH=true

# Global Umans API serialization lock. Only one Umans request is in flight at a
# time across sourcing/social/document tasks. Set to true only for tests/local.
UMANS_API_LOCK_DISABLED=false

# TTL (seconds) for the shared Umans API lock. Should be longer than the longest
# expected request timeout.
UMANS_API_LOCK_TTL_SECONDS=120

# Max time (seconds) to wait for the shared Umans API lock before proceeding anyway.
UMANS_API_LOCK_TIMEOUT_SECONDS=30

# Optional throttle (seconds) between Umans API calls. Leave at 0 unless still
# hitting rate limits after the lock and wallet key are in place.
UMANS_API_CALL_DELAY_SECONDS=0

# Circuit breaker: open after this many consecutive retryable failures (429/5xx).
UMANS_CIRCUIT_BREAKER_FAILURE_THRESHOLD=3

# Circuit breaker: stay open for this many seconds before allowing calls again.
UMANS_CIRCUIT_BREAKER_COOLDOWN_SECONDS=600

# Retry/backoff for LLM-backed Celery tasks
SOURCING_RETRY_BASE_DELAY=120
SOCIAL_RESEARCH_RETRY_BASE_DELAY=120
DOCUMENT_RETRY_BASE_DELAY=120

# Minimum retry countdown in seconds. Prevents the API's small Retry-After values
# from causing tight retry loops. Increase this if you see repeated overloaded_error.
MIN_RETRY_DELAY_SECONDS=120

# Default cadence for seeded sourcing schedules (seconds). 3600 = 1 hour.
DEFAULT_SOURCING_INTERVAL_SECONDS=3600

# PostgreSQL database URL
DATABASE_URL=postgresql://postgres:password@localhost:5432/founderos

# Celery + Redis configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
# Set to true in tests or local single-process mode to run tasks synchronously
CELERY_ALWAYS_EAGER=false

# How often the Celery beat scheduler checks for due sourcing schedules (seconds)
SOURCING_DISPATCH_INTERVAL_SECONDS=60

# Distributed lock TTL for the pool refresh task (seconds)
POOL_LOCK_TTL_SECONDS=300

# Backend log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Optional: port the uvicorn server listens on (Railway injects this automatically)
PORT=8000
