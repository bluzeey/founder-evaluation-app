# Railway / local backend environment variables

# Required: Umans Code API key from https://app.umans.ai/billing
UMANS_API_KEY=sk-your-umans-api-key

# Optional: web search backend. Options: native (Kimi-backed), exa, none
UMANS_WEBSEARCH_PROVIDER=native

# Optional: model alias. Options: umans-coder, umans-kimi-k2.7, umans-glm-5.2, umans-flash
UMANS_MODEL=umans-coder

# Optional: HTTP timeout in seconds for research calls
UMANS_RESEARCH_TIMEOUT=60

# Optional: dedicated model for social background research
UMANS_SOCIAL_MODEL=umans-coder

# PostgreSQL database URL
DATABASE_URL=postgresql://postgres:password@localhost:5432/founderos

# Celery + Redis configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
# Set to true in tests or local single-process mode to run tasks synchronously
CELERY_ALWAYS_EAGER=false

# How often the Celery beat scheduler triggers pool discovery (seconds)
POOL_REFRESH_INTERVAL_SECONDS=3600

# Distributed lock TTL for the pool refresh task (seconds)
POOL_LOCK_TTL_SECONDS=300

# Backend log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Optional: port the uvicorn server listens on (Railway injects this automatically)
PORT=8000
