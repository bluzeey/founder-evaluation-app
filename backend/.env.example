# Railway / local backend environment variables

# Required: OpenAI API key
OPENAI_API_KEY=sk-your-openai-api-key

# Optional: OpenAI base URL. Change this if using a proxy or Azure OpenAI.
OPENAI_BASE_URL=https://api.openai.com/v1/chat/completions

# Optional: default model aliases. OpenAI's gpt-4o is deprecated; use gpt-5.
OPENAI_MODEL=gpt-5
OPENAI_SOURCING_MODEL=gpt-5
OPENAI_SOCIAL_MODEL=gpt-5
OPENAI_DOCUMENT_MODEL=gpt-5

# Optional: HTTP timeout in seconds for OpenAI calls
OPENAI_TIMEOUT=60

# Optional: max tokens for OpenAI calls (default 8000)
OPENAI_MAX_TOKENS=8000

# Optional: global web-search toggle. Per-agent toggles below take precedence.
OPENAI_ENABLE_WEB_SEARCH=true

# Per-agent web search toggles. These override OPENAI_ENABLE_WEB_SEARCH.
# Sourcing needs real-time discovery, so it defaults to true.
OPENAI_ENABLE_WEB_SEARCH_SOURCING=true
# Social research usually receives LinkedIn/GitHub URLs, so web search defaults
# to false to reduce API load. Set to true if you want the model to search.
OPENAI_ENABLE_WEB_SEARCH_SOCIAL=false
# Founder research (POST /v1/founders/research) defaults to true.
OPENAI_ENABLE_WEB_SEARCH_RESEARCH=true

# Web search is handled by Tavily. Set to false to disable web search entirely.
TAVILY_API_KEY=tvly-your-tavily-api-key
TAVILY_SEARCH_DEPTH=basic
TAVILY_MAX_RESULTS=5
TAVILY_TIMEOUT=30

# Global LLM API serialization lock. Only one OpenAI request is in flight at a
# time across sourcing/social/document tasks. Set to true only for tests/local.
API_LOCK_DISABLED=false

# TTL (seconds) for the shared LLM API lock. Should be longer than the longest
# expected request timeout.
API_LOCK_TTL_SECONDS=120

# Max time (seconds) to wait for the shared LLM API lock before proceeding anyway.
API_LOCK_TIMEOUT_SECONDS=30

# Optional throttle (seconds) between LLM API calls. Leave at 0 unless still
# hitting rate limits after the lock is in place.
API_CALL_DELAY_SECONDS=0

# Circuit breaker: open after this many consecutive retryable failures (429/5xx).
CIRCUIT_BREAKER_FAILURE_THRESHOLD=3

# Circuit breaker: stay open for this many seconds before allowing calls again.
CIRCUIT_BREAKER_COOLDOWN_SECONDS=600

# Retry/backoff for LLM-backed Celery tasks
SOURCING_RETRY_BASE_DELAY=120
SOCIAL_RESEARCH_RETRY_BASE_DELAY=120
DOCUMENT_RETRY_BASE_DELAY=120

# Minimum retry countdown in seconds. Prevents the API's small Retry-After values
# from causing tight retry loops.
MIN_RETRY_DELAY_SECONDS=120

# Default cadence for seeded sourcing schedules (seconds). 3600 = 1 hour.
DEFAULT_SOURCING_INTERVAL_SECONDS=3600

# PostgreSQL database URL
DATABASE_URL=postgresql://postgres:password@localhost:5432/founderos

# Celery + Redis configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
# Set to true in tests or local single-process mode to run tasks synchronously
CELERY_ALWAYS_EAGER=false

# How often the Celery beat scheduler checks for due sourcing schedules (seconds)
SOURCING_DISPATCH_INTERVAL_SECONDS=60

# Distributed lock TTL for the pool refresh task (seconds)
POOL_LOCK_TTL_SECONDS=300

# Backend log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Optional: port the uvicorn server listens on (Railway injects this automatically)
PORT=8000
